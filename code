class AgregateurAnnuel:
    def __init__(self,zgeo,tinfo,annees,values):
        self.__zgeo = zgeo
        self.__tinfo = tinfo
        self.__annees = annees
        self.__values =values
        self.__a = dict()
        for i in range(0,len(annees)):
            self.__a.update({annees[i]:values[i]})

                
    def ajouter(self,new,annee):
        if annee in self.__a:
            x = self.__a[annee]
            self.__a.update({annee:x+new})
        else:
            self.__a.update({annee:new})
        

        def obtenir_serie(self):
        donnes = []
        donnes.append(self.__tinfo)
        donnean = []
        donneval = []
        for i in self.__a:
            donnean.append(i)
            donneval.append(self.__a[i])
        donnes.append(donnean)
        donnes.append(donneval)
        return(donnes)
        
        
        
        
def construire_agregats_annuels(liste, entetes,
                                nom, dictionnaire):
 
    idx_region = entetes.trouverIndex("Code INSEE rÃ©gion")
