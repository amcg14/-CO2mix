def normaliser(nom):
    # Supprime les accents, Passe en minuscule et ne garde que les lettres
    sans_accent = unicodedata.normalize("NFD", nom)
    sans_accent = "".join(
        c for c in sans_accent if unicodedata.category(c) != "Mn"
        )
    return "".join(c for c in sans_accent.lower() if c.isalpha())
    

# Autre méthode pou normaliser les noms
def acc_minus(nom):
    accents = { 'à':'a', 'á':'a', 'â':'a', 'ä':'a',
        'è':'e', 'é':'e', 'ê':'e', 'ë':'e',
        'ì':'i', 'í':'i', 'î':'i', 'ï':'i',
        'ò':'o', 'ó':'o', 'ô':'o', 'ö':'o',
        'ù':'u', 'ú':'u', 'û':'u', 'ü':'u',
        'ç':'c',
        'À':'A', 'É':'E'
    }
    resultat = ""
    for caracter in nom :
        if caracter in accents :
            resultat += accents[caracter]
        else:
            resultat += caracter
    return resultat.lower()
               
def onlyletter(nom):
    resultat = ""
    for caracter in nom :
        if caracter.isalpha():
            resultat += caracter
    return acc_minus(resultat)
 
