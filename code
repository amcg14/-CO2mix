    idx_solaire = entetes.trouverIndex("Solaire (MW)")
    idx_eolienne = entetes.trouverIndex("Eolien (MW)")
    idx_hydraulique = entetes.trouverIndex("Hydraulique (MW)")
    idx_nucleaire = entetes.trouverIndex("NuclÃ©aire (MW)")
    idx_date = entetes.trouverIndex("Date")
    
    annees =[2013,2014,2015,2016,2017,2018,2019,2020,2021,2022,2023,2024]
