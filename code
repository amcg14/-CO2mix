    for ligne in liste:

        colonnes = ligne.strip().split(";")
        
        
#entetes.separateur()
        region = colonnes[idx_region]

        # filtrage région
        if nom != "France":

            code = dictionnaire[nom]

            if region != code:
                continue

        # lecture consommation
        try:
            conso = float(colonnes[idx_conso])
        except:
            conso = 0

